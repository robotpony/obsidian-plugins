{
  "name": "g-command-gdrive",
  "version": "1.0.0",
  "description": "MCP server for read-only Google Drive access via rclone",
  "license": "MIT",
  "type": "module",
  "bin": {
    "g-command-gdrive": "dist/gdrive/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/gdrive/index.js",
    "prepare": "npm run build",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "fuse.js": "7.1.0",
    "turndown": "7.2.0",
    "turndown-plugin-gfm": "1.0.2"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "@types/turndown": "5.0.4",
    "shx": "0.3.4",
    "typescript": "5.9.3"
  }
}
