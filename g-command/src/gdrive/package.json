{
  "name": "g-command-gdrive",
  "version": "1.0.0",
  "description": "MCP server for read-only Google Drive access via rclone",
  "license": "MIT",
  "type": "module",
  "bin": {
    "g-command-gdrive": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && shx chmod +x dist/*.js",
    "prepare": "npm run build",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0"
  },
  "devDependencies": {
    "@types/node": "22.19.15",
    "shx": "0.3.4",
    "typescript": "5.9.3"
  }
}
